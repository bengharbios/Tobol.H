                    <!-- Loading Indicator -->
                    <div id="loading-trigger" class="flex justify-center py-8">
                        <div class="loading-spinner hidden">
                            <svg class="animate-spin h-8 w-8 md:h-10 md:w-10 text-violet-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
