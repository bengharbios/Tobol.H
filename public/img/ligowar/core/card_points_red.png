        </main>

<!-- Code Game Iframe Overlay -->
<div id="code-game-overlay" class="fixed inset-0 z-[9999] hidden bg-black flex-col">
    <!-- Clean Fullscreen View: No Header -->
    
    <!-- Iframe Container -->
    <div class="flex-1 w-full h-full relative">
        <iframe id="code-game-iframe" class="w-full h-full border-0 absolute inset-0" sandbox="allow-same-origin allow-scripts allow-popups allow-forms allow-pointer-lock allow-top-navigation allow-modals allow-downloads" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen; gamepad; microphone; camera" allowfullscreen></iframe>
    </div>

    <!-- Improved Close Button with High Z-Index -->
<button onclick="confirmCloseGame()" class="fixed bottom-0 left-0 z-[10000] w-12 h-12 bg-white/10 hover:bg-red-500/80 backdrop-blur-md border-r border-t border-white/20 transition-all duration-300 shadow-2xl group" title="إغلاق اللعبة" style="touch-action: manipulation; clip-path: polygon(0 0, 100% 100%, 0 100%);">
    <!-- Icon inside triangle -->
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="absolute bottom-1 left-1 text-white/80 group-hover:text-white transform transition-transform group-hover:scale-110">
        <path d="M19 12H5M5 12L12 5M5 12L12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
</button>
</div>

<style>
    /* Critical: Ensure SweetAlert appears above everything, including the overlay */
    body.swal2-shown > [aria-hidden="true"] {
        transition: 0.1s filter;
        filter: blur(10px);
    }
    .swal2-container {
        z-index: 2147483647 !important; /* Max Z-Index possible */
    }
</style>

<script>
    // Search Placeholder Animation
    const suggestions = [
        "12345", "لعبة المجازفة", "56789", "حرب الطبول", "10203", "حرب الفواكه",
        "مسابقات ثقافية", "حكم أو جُرأة", "لو خيروك"
    ];
    const inputs = document.querySelectorAll("input[name='slug']");
    inputs.forEach(input => {
        let index = 0;
        let userTyped = false;

        input.addEventListener('focus', () => { input.value = ''; userTyped = true; });
        input.addEventListener('input', () => { userTyped = input.value.trim().length > 0; });

        setInterval(() => {
            if (!userTyped) {
                input.setAttribute('placeholder', 'جرب: ' + suggestions[index]);
                index = (index + 1) % suggestions.length;
            }
        }, 3000);
    });

    // --- GAME CODE SEARCH LOGIC ---
    document.addEventListener('DOMContentLoaded', () => {
        const searchForm = document.getElementById('hero-search-form');
        const searchInput = document.getElementById('hero-search-input');

        if(searchForm) {
            searchForm.addEventListener('submit', async (e) => {
                const query = searchInput.value.trim();
                
                // Check if query is a 4-6 digit number
                if (/^\d{4,6}$/.test(query)) {
                    e.preventDefault(); // Stop normal search
                    handleGameCode(query);
                }
                // Else: Allow normal form submission (Standard Search)
            });
        }
    });

    async function handleGameCode(code) {
        // Show Loading
        Swal.fire({
            title: 'جاري التحقق من الكود...',
            text: 'يرجى الانتظار لحظات',
            icon: 'info',
            background: '#1E2A45',
            color: '#fff',
            showConfirmButton: false,
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            // Call the API
            const response = await fetch(`https://loveligo.com//OurApps/url-shortener/api.php?code=${code}`);
            
            // Note: Even on 404, we might get a valid response object, so we check status or json content
            const data = await response.json();
            
            if (data.success && data.original_url) {
                Swal.close();
                openCodeGame(data.original_url);
            } else {
                // Explicitly show "ID not found" if success is false
                Swal.fire({
                    icon: 'error',
                    title: 'تنبيه',
                    text: 'عذراً، لم يتم العثور على لعبة بهذا المعرف (الكود غير صحيح)',
                    background: '#1E2A45',
                    color: '#fff',
                    confirmButtonText: 'حسناً',
                    confirmButtonColor: '#8B5CF6'
                });
            }
        } catch (error) {
            // This catches actual network errors (offline, server down)
            Swal.fire({
                icon: 'error',
                title: 'خطأ',
                text: 'حدث خطأ في الاتصال بالخادم، يرجى المحاولة لاحقاً',
                background: '#1E2A45',
                color: '#fff'
            });
        }
    }

    function openCodeGame(url) {
        const overlay = document.getElementById('code-game-overlay');
        const iframe = document.getElementById('code-game-iframe');
        
        iframe.src = url;
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.style.overflow = 'hidden'; // Prevent scrolling
    }

    // Attach function to window to ensure visibility
    window.confirmCloseGame = function() {
        console.log('Close button clicked'); // Debugging
        
        Swal.fire({
            title: 'هل تريد الخروج؟',
            text: "سيتم إغلاق اللعبة الحالية والعودة للصفحة الرئيسية",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'نعم، إغلاق',
            cancelButtonText: 'إلغاء',
            background: '#1E2A45',
            color: '#fff',
            backdrop: true,
            // Ensure proper z-index stacking context
            target: 'body' 
        }).then((result) => {
            if (result.isConfirmed) {
                closeCodeGame();
            }
        });
    }

    function closeCodeGame() {
        const overlay = document.getElementById('code-game-overlay');
        const iframe = document.getElementById('code-game-iframe');
        
        iframe.src = '';
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        document.body.style.overflow = '';
    }

    // Infinite Scroll Logic for Home Page
    document.addEventListener('DOMContentLoaded', function() {
        let nextPage = 2;
        let isLoading = false;
        // Get max pages from PHP
        const maxPages = 4;
        
        const grid = document.getElementById('latest-games-grid');
        const loaderTrigger = document.getElementById('loading-trigger');
        const spinner = loaderTrigger.querySelector('.loading-spinner');
        const allGamesUrl = "https://loveligo.com/all-games/"; 

        if (grid && loaderTrigger) {
            const observer = new IntersectionObserver(async (entries) => {
                // Check if intersecting, not loading, AND nextPage is within limit
                if (entries[0].isIntersecting && !isLoading && nextPage <= maxPages) {
                    isLoading = true;
                    spinner.classList.remove('hidden');

                    try {
                        let fetchUrl = allGamesUrl;
                        // Better URL construction logic
                        let baseUrl = allGamesUrl.replace(/\/$/, "");
                        
                        if (baseUrl.indexOf('?') === -1) {
                            // No query params, use pretty url format
                            fetchUrl = `${baseUrl}/${nextPage}`;
                        } else {
                            // Query params exist, append page param
                            fetchUrl = `${baseUrl}&page=${nextPage}`;
                        }
                        
                        const response = await fetch(fetchUrl);
                        const text = await response.text();
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(text, 'text/html');
                        
                        // Select cards from the All Games grid. 
                        const newItems = doc.querySelectorAll('#all-games-grid > *');

                        if (newItems.length > 0) {
                            // DUPLICATE CHECK: Prevent infinite loops if server returns same page
                            const firstNewLink = newItems[0].querySelector('a')?.href;
                            const firstExistingLink = grid.querySelector('a')?.href;
                            
                            if (firstNewLink && firstExistingLink && firstNewLink === firstExistingLink) {
                                // We received the first page again. Stop immediately.
                                loaderTrigger.style.display = 'none';
                                observer.disconnect();
                                isLoading = false;
                                spinner.classList.add('hidden');
                                return;
                            }

                            newItems.forEach(item => {
                                // Clone to avoid reference issues
                                grid.appendChild(item.cloneNode(true));
                            });
                            nextPage++;
                            
                            // Check if we reached the end after incrementing
                            if (nextPage > maxPages) {
                                loaderTrigger.style.display = 'none';
                                observer.disconnect();
                            }

                            // Trigger LazyLoad if available
                            if(window.lazySizes) {
                                window.lazySizes.loader.checkElems();
                            }
                        } else {
                            // No items found (safeguard)
                            loaderTrigger.style.display = 'none';
                            observer.disconnect();
                        }
                    } catch (error) {
                        console.error('Error loading more games:', error);
                        // Optional: Hide loader on error to prevent stuck spinner
                        loaderTrigger.style.display = 'none'; 
                    }

                    isLoading = false;
                    spinner.classList.add('hidden');
                } else if (nextPage > maxPages) {
                    // Hide loader if we exceed max pages
                    loaderTrigger.style.display = 'none';
                    observer.disconnect();
                }
            }, { rootMargin: '200px' });

            observer.observe(loaderTrigger);
        } else if (nextPage > maxPages) {
             // Initial check if only 1 page exists
             if(loaderTrigger) loaderTrigger.style.display = 'none';
        }
    });
</script>

